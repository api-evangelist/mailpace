              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "MailPace-Server-Token",
                "value": "{{serverToken}}"
              }
            ],
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from\": \"Acme <noreply@acme.com>\",\n  \"to\": \"user@example.com\",\n  \"subject\": \"Welcome to Acme\",\n  \"textbody\": \"Thanks for signing up.\"\n}",
              "options": {
